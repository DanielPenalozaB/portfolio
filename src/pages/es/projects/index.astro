---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import ProjectCard from "../../../components/ProjectCard.astro";
import { useTranslations } from "../../../i18n";

const t = useTranslations("es");

const projects = await getCollection("projects", ({ id }) => {
  return id.startsWith("es/");
});
---

<Layout title={t("projects.title")} description={t("projects.description")}>
  <section
    class="flex min-h-screen flex-col items-center px-6 py-20 sm:px-10"
  >
    <div class="flex w-full max-w-5xl flex-col gap-12">
      <div class="reveal flex flex-col gap-4">
        <h1
          class="dm-serif-display text-4xl font-bold text-stone-800 sm:text-5xl dark:text-stone-100"
        >
          {t("projects.title")}
        </h1>
        <p class="m-0! text-lg text-stone-600 dark:text-stone-400">
          {t("projects.description")}
        </p>
      </div>

      <div
        class="reveal reveal-delay-1 grid w-full grid-cols-1 gap-8 lg:grid-cols-2"
      >
        {
          projects.map((project, index) => (
            <ProjectCard
              data={project.data}
              class={index < 2 ? "lg:col-span-2" : ""}
              isFeatured={index < 2}
              darkStandalone
            />
          ))
        }
      </div>
    </div>
  </section>
</Layout>
