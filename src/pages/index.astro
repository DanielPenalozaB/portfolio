---
import { getCollection } from "astro:content";
import CertificatesSection from "../components/CertificatesSection.astro";
import ExperienceSection from "../components/ExperienceSection.astro";
import OrbitalHero from "../components/OrbitalHero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import ThoughtsSection from "../components/ThoughtsSection.astro";
import ToolsSection from "../components/ToolsSection.astro";
import Layout from "../layouts/Layout.astro";

const projects = await getCollection("projects", ({ id }) => {
  return id.startsWith("en/");
});
---

<Layout>
  <OrbitalHero />
  <ProjectsSection>
    {
      projects.map((project, index) => (
        <ProjectCard
          data={project.data}
          class={index < 2 ? "lg:col-span-2" : ""}
          isFeatured={index < 2}
        />
      ))
    }
  </ProjectsSection>
  <ToolsSection />
  <ExperienceSection />
  <CertificatesSection />
  <ThoughtsSection />
</Layout>
