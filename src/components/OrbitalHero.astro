---
import { ORBIT_RINGS } from "../data/orbits";
import { getLocaleFromUrl, useTranslations, type Locale } from "../i18n";

const locale: Locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<section
  id="orbital-hero"
  class="relative z-0 flex h-[800px] w-full items-center justify-center"
>
  <style>
    .perspective-1000 {
      perspective: 1000px;
    }
    .preserve-3d {
      transform-style: preserve-3d;
    }
    .backface-hidden {
      backface-visibility: hidden;
    }
    .rotate-y-180 {
      transform: rotateY(180deg);
    }
  </style>

  <div class="relative z-10 flex flex-col items-center gap-12">
    <h1 class="text-4xl! font-light text-stone-800 sm:text-5xl!">
      {t("hero.greeting")}{" "}
      <span class="dm-serif-display font-semibold">{t("hero.name")}</span>
    </h1>

    <div
      id="profile-container"
      class="perspective-1000 h-52 w-52 cursor-pointer"
    >
      <div id="profile-flipper" class="preserve-3d relative h-full w-full">
        <!-- Front Side (Image) -->
        <div class="absolute inset-0 backface-hidden">
          <img
            src="/images/profile.png"
            alt="Profile"
            class="h-full w-full rounded-4xl! object-cover"
          />
        </div>

        <!-- Back Side (Text) -->
        <div
          class="absolute inset-0 flex rotate-y-180 items-center justify-center rounded-4xl bg-white text-center backface-hidden"
        >
          <svg
            viewBox="0 0 200 200"
            class="h-full w-full animate-[spin_20s_linear_infinite] p-2"
          >
            <path
              id="circlePath"
              d="M 100, 100 m -70, 0 a 70,70 0 1,1 140,0 a 70,70 0 1,1 -140,0"
              fill="none"></path>
            <text
              class="dm-serif-display fill-stone-800 text-[11.5px] font-semibold tracking-widest uppercase"
            >
              <textPath
                href="#circlePath"
                startOffset="50%"
                text-anchor="middle"
              >
                {t("hero.roles")}
              </textPath>
            </text>
          </svg>
          <div
            class="pointer-events-none absolute inset-0 flex items-center justify-center"
          >
            <span class="text-2xl">🚀</span>
          </div>
        </div>
      </div>
    </div>

    <button
      type="button"
      class="group flex cursor-pointer items-center gap-2 rounded-full bg-[#6C969D] p-1 pl-3.5 text-sm font-medium tracking-wider text-stone-100 hover:bg-[#6C969D]/80"
    >
      <span>{t("hero.download")}</span>
      <div
        class="flex h-8 w-8 items-center justify-center rounded-full bg-stone-200 group-hover:bg-stone-100"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M12 5V19"
            stroke="#6C969D"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <path
            d="M19 12L12 19L5 12"
            stroke="#6C969D"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
    </button>
  </div>

  <div
    id="orbits-container"
    class="pointer-events-auto absolute inset-0 flex items-center justify-center overflow-visible"
  >
    <!-- Visual Rings -->
    <div
      class="absolute h-[706px] w-[706px] rounded-full border-4 border-stone-200/50!"
    >
    </div>
    <div
      class="absolute h-[956px] w-[956px] rounded-full border-4 border-stone-200/50!"
    >
    </div>
    <div
      class="absolute h-[1216px] w-[1216px] rounded-full border-4 border-stone-200/50!"
    >
    </div>

    <!-- Orbit Arms -->
    {
      ORBIT_RINGS.map((orbit) => (
        <>
          {orbit.items.map((item, idx) => {
            const angle = (360 / orbit.items.length) * idx;
            return (
              <div
                class="orbit-arm absolute"
                style={{
                  width: `${orbit.radius}px`,
                  height: "0px",
                  left: "50%",
                  top: "50%",
                  transformOrigin: "left center",
                  zIndex: 20,
                }}
                data-speed={orbit.speed}
                data-direction={orbit.direction}
                data-radius={orbit.radius}
                data-initial-angle={angle}
              >
                <div
                  class="absolute right-0"
                  style={{ transform: "translate(50%, -50%)" }}
                >
                  <div class="orbit-item-rotator">
                    <div class="orbit-item group relative cursor-pointer transition-transform duration-200 hover:scale-110">
                      <div
                        class="flex h-14 w-14 items-center justify-center rounded-2xl border border-gray-100 bg-white p-3 shadow-lg"
                        title={item.label}
                      >
                        <img
                          src={item.icon}
                          alt={item.label}
                          class="h-full w-full object-contain"
                        />
                      </div>
                      <span class="pointer-events-none absolute -bottom-7 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-md bg-stone-800 px-2 py-0.5 text-xs text-white opacity-0 transition-opacity group-hover:opacity-100">
                        {item.label}
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </>
      ))
    }
  </div>

  <!-- Background Gradients -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_center,var(--tw-gradient-stops))] from-blue-50/50 via-gray-50/50 to-white/0 dark:from-blue-950/30 dark:via-gray-950/30 dark:to-black/0"
  >
  </div>
</section>

<script>
  import gsap from "gsap";

  const arms = document.querySelectorAll<HTMLElement>(".orbit-arm");
  const orbitsContainer = document.getElementById("orbits-container");

  const orbitTimelines: Map<number, gsap.core.Timeline> = new Map();

  if (arms.length > 0) {
    arms.forEach((arm) => {
      const speed = parseFloat(arm.dataset.speed || "25");
      const direction = parseFloat(arm.dataset.direction || "1");
      const radius = parseFloat(arm.dataset.radius || "353");
      const initialAngle = parseFloat(arm.dataset.initialAngle || "0");
      const rotator = arm.querySelector(".orbit-item-rotator");

      gsap.set(arm, { rotation: initialAngle });
      if (rotator) {
        gsap.set(rotator, { rotation: -initialAngle });
      }

      if (!orbitTimelines.has(radius)) {
        orbitTimelines.set(radius, gsap.timeline());
      }
      const timeline = orbitTimelines.get(radius)!;

      timeline.to(
        arm,
        {
          rotation: `+=${360 * direction}`,
          duration: speed,
          repeat: -1,
          ease: "none",
        },
        0,
      );

      if (rotator) {
        timeline.to(
          rotator,
          {
            rotation: `-=${360 * direction}`,
            duration: speed,
            repeat: -1,
            ease: "none",
          },
          0,
        );
      }
    });

    // Per-orbit hover slowdown based on mouse distance from center
    if (orbitsContainer) {
      const hitZone = 60;

      orbitsContainer.addEventListener("mousemove", (e) => {
        const rect = orbitsContainer.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;
        const dist = Math.sqrt(
          (e.clientX - centerX) ** 2 + (e.clientY - centerY) ** 2,
        );

        orbitTimelines.forEach((tl, radius) => {
          const isHovered = Math.abs(dist - radius) < hitZone;
          gsap.to(tl, {
            timeScale: isHovered ? 0.1 : 1,
            duration: 0.6,
            overwrite: true,
          });
        });
      });

      orbitsContainer.addEventListener("mouseleave", () => {
        orbitTimelines.forEach((tl) => {
          gsap.to(tl, { timeScale: 1, duration: 0.6, overwrite: true });
        });
      });
    }
  }

  // Profile card: 3D tilt + flip on hover
  const profileContainer = document.getElementById("profile-container");
  const profileFlipper = document.getElementById("profile-flipper");

  if (profileContainer && profileFlipper) {
    let isFlipped = false;

    profileContainer.addEventListener("mouseenter", () => {
      isFlipped = true;
      gsap.to(profileFlipper, {
        rotationY: 180,
        duration: 0.6,
        ease: "power2.inOut",
      });
    });

    profileContainer.addEventListener("mousemove", (e) => {
      const rect = profileContainer.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      const y = (e.clientY - rect.top) / rect.height;

      const tiltX = (y - 0.5) * -40;
      const tiltY = (x - 0.5) * 40;
      const baseY = isFlipped ? 180 : 0;

      gsap.to(profileFlipper, {
        rotateX: tiltX,
        rotationY: baseY + tiltY,
        duration: 0.3,
        ease: "power2.out",
      });
    });

    profileContainer.addEventListener("mouseleave", () => {
      isFlipped = false;
      gsap.to(profileFlipper, {
        rotationY: 0,
        rotateX: 0,
        duration: 0.6,
        ease: "power2.inOut",
      });
    });
  }
</script>
