---
import { getLocaleFromUrl, type Locale } from "../i18n";

interface Props {
  date: Date;
}

const { date } = Astro.props;
const locale: Locale = getLocaleFromUrl(Astro.url);
const formattedLocale = locale === "es" ? "es-ES" : "en-US";
---

<time datetime={date.toISOString()}>
  {
    date.toLocaleDateString(formattedLocale, {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  }
</time>
