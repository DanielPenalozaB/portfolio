---
import { PROFILE_MARQUEES } from "../data/marquees";

interface Props {
  profileImage?: string;
}

const { profileImage = "/images/profile.png" } = Astro.props;
---

<div
  id="profile-container"
  role="button"
  tabindex="0"
  aria-label="Flip profile card to see skills"
  class="perspective-1000 relative h-64 w-64 cursor-pointer"
>
  <div id="profile-flipper" class="preserve-3d relative h-full w-full">
    <!-- Front Side (Image) -->
    <div class="absolute inset-0 backface-hidden">
      <img
        src={profileImage}
        alt="Daniel Peñaloza"
        class="h-full w-full rounded-4xl! object-cover"
        fetchpriority="high"
      />
      <!-- Click indicator -->
      <div
        class="absolute -right-2 -bottom-2 flex h-8 w-8 items-center justify-center rounded-full bg-white shadow-md"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#6C969D"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M15 15l6 6m-6-6v4.8m0-4.8h4.8"></path>
          <path
            d="M9 19.8V14H4.2M9 9l-6-6m6 6V4.2M9 9H4.2M15 4.2V9m0 0h4.8M15 9l6-6"
          ></path>
        </svg>
      </div>
    </div>

    <!-- Back Side (Infinite sliders) -->
    <div
      class="absolute inset-0 flex rotate-y-180 rounded-4xl border-4 border-slate-700 bg-white p-6 backface-hidden"
    >
      <div
        class="flex flex-col justify-between overflow-hidden rounded-lg border-4 border-slate-700"
      >
        {
          PROFILE_MARQUEES.map((slider) => (
            <div class="marquee-container overflow-hidden first:border-t-0 last:border-b-0 border-y-4 border-stone-700 py-2">
              <div
                class={`marquee-track marquee-${slider.direction} flex w-max gap-6`}
              >
                {[...slider.words, ...slider.words].map((word) => (
                  <span class="whitespace-nowrap text-lg font-medium uppercase text-stone-700">
                    {word}
                  </span>
                ))}
              </div>
              <span class="absolute top-0 left-0 rounded-sm rounded-l-none bg-[#6C969D] px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wide text-white">
                {slider.label}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }
  .preserve-3d {
    transform-style: preserve-3d;
  }
  .backface-hidden {
    backface-visibility: hidden;
  }
  .rotate-y-180 {
    transform: rotateY(180deg);
  }
  .marquee-container {
    position: relative;
  }
  .marquee-track {
    animation-duration: 20s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }
  .marquee-left {
    animation-name: marquee-left;
  }
  .marquee-right {
    animation-name: marquee-right;
  }
  @keyframes marquee-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  @keyframes marquee-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }
</style>
