---
import { CERTIFICATES } from "../data/certificates";
import { getLocaleFromUrl, useTranslations, type Locale } from "../i18n";
import CertificateCard from "./CertificateCard.astro";

const locale: Locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<section
  id="certificates"
  class="flex flex-col items-center overflow-hidden px-6 py-20 sm:px-10 sm:py-32"
>
  <div
    class="flex w-full max-w-5xl flex-col gap-10 lg:flex-row lg:items-start lg:gap-16"
  >
    <!-- Left: Title + subtitle -->
    <div class="flex shrink-0 flex-col gap-4 lg:w-72">
      <h2
        class="dm-serif-display text-4xl font-bold text-stone-800! sm:text-5xl"
      >
        {t("certificates.title")}
      </h2>
      <p class="text-sm leading-relaxed text-stone-500">
        {t("certificates.subtitle")}
      </p>
    </div>

    <!-- Right: Certificate cards -->
    <div class="flex flex-1 flex-wrap items-start gap-6">
      {CERTIFICATES.map((cert) => <CertificateCard certificate={cert} />)}

      <!-- "More incoming" placeholder card -->
      <div
        class="flex h-72 w-56 flex-col items-center justify-center gap-4 rounded-3xl bg-stone-700 p-6 text-center sm:h-80 sm:w-64"
      >
        <p class="text-lg font-bold text-stone-200">
          {t("certificates.moreIncoming")}
        </p>
        <svg
          class="h-24 w-24 text-stone-500"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"
          ></path>
        </svg>
      </div>

      <!-- Empty placeholder cards -->
      <div
        class="h-56 w-56 rounded-3xl border border-dashed border-stone-200 bg-stone-50 sm:h-64 sm:w-64"
      >
      </div>
    </div>
  </div>
</section>
