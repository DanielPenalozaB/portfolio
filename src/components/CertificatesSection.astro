---
import { CERTIFICATES } from "../data/certificates";
import { getLocaleFromUrl, useTranslations, type Locale } from "../i18n";
import CertificateCard from "./CertificateCard.astro";

const locale: Locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<section
  id="certificates"
  class="flex flex-col items-center gap-16 px-10 py-40"
>
  <div
    class="flex max-w-5xl flex-col items-center gap-8 md:items-start lg:w-full lg:flex-row"
  >
    <div class="flex flex-col gap-4 py-8">
      <h2 class="dm-serif-display text-4xl font-bold sm:text-5xl">
        {t("certificates.title")}
      </h2>
      <p class="m-0! max-w-xl text-2xl leading-tight font-light text-stone-600">
        {t("certificates.subtitle")}
      </p>
    </div>
    <div
      class="grid grid-flow-col grid-cols-[300px] grid-rows-[repeat(3,300px)] gap-4 md:grid-cols-[repeat(2,300px)] md:grid-rows-[repeat(2,300px)] md:gap-8"
    >
      {CERTIFICATES.map((cert) => <CertificateCard certificate={cert} />)}

      <!-- "More incoming" placeholder card -->
      <div
        class="relative flex h-full w-full flex-col items-center justify-center gap-16 overflow-hidden rounded-4xl bg-stone-800 p-4 md:row-span-2"
      >
        <p class="z-10 m-0! text-xl font-medium tracking-widest text-stone-300">
          {t("certificates.moreIncoming")}
        </p>
        <svg
          width="160"
          height="160"
