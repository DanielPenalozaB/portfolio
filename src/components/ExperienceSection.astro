---
import { EXPERIENCE } from "../data/experience";
import { getLocaleFromUrl, useTranslations, type Locale } from "../i18n";
import ExperienceEntry from "./ExperienceEntry.astro";

const locale: Locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<section id="experience" class="flex flex-col items-center gap-16 px-10 py-40">
  <div class="flex w-full max-w-5xl flex-col gap-16">
    <h2 class="dm-serif-display text-4xl font-bold text-stone-800! sm:text-5xl">
      {t("experience.title")}
    </h2>
    <div class="flex w-full flex-col divide-y-2 divide-stone-300">
      {EXPERIENCE.map((entry) => <ExperienceEntry entry={entry} />)}
    </div>
  </div>
</section>
