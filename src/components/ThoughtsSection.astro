---
import { getCollection } from "astro:content";
import ThoughtCard from "./ThoughtCard.astro";
import {
  getLocaleFromUrl,
  getLocalizedPath,
  useTranslations,
  type Locale,
} from "../i18n";

const locale: Locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section
  id="thoughts"
  class="flex flex-col items-center gap-16 bg-stone-50 px-6 py-20 sm:px-10 sm:py-32"
>
  <div class="flex max-w-5xl flex-col items-center gap-4 text-center">
    <h2 class="dm-serif-display text-4xl font-bold text-stone-800! sm:text-5xl">
      {t("thoughts.title")}
    </h2>
    <p class="max-w-xl text-lg text-stone-500">{t("thoughts.subtitle")}</p>
  </div>

  <div class="grid w-full max-w-5xl gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {posts.map((post) => <ThoughtCard post={post} />)}
  </div>

  <a
    href={getLocalizedPath("/blog", locale)}
    class="rounded-full border border-stone-300 px-6 py-2.5 text-sm font-medium text-stone-600 transition-all hover:border-[#6C969D] hover:text-[#6C969D]"
  >
    {t("thoughts.viewAll")}
  </a>
</section>
