---
import { getCollection } from "astro:content";
import ThoughtCard from "./ThoughtCard.astro";
import {
  getLocaleFromUrl,
  getLocalizedPath,
  useTranslations,
  type Locale,
} from "../i18n";

const locale: Locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const posts = (await getCollection("blog"))
  .filter((post) => post.data.heroImage)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section
  id="thoughts"
  aria-labelledby="thoughts-heading"
  class="flex flex-col items-center gap-16 px-10 py-40"
>
  <div class="flex w-full max-w-5xl flex-col gap-16">
    <div class="flex max-w-5xl flex-col items-center gap-4 text-center">
      <h2
        id="thoughts-heading"
        class="reveal dm-serif-display text-4xl font-bold text-stone-800! sm:text-5xl dark:text-stone-100!"
      >
        {t("thoughts.title")}
      </h2>
    </div>
    <div
      class="reveal reveal-delay-1 flex w-full flex-col divide-y-2 divide-stone-300 dark:divide-stone-700"
    >
      {posts.map((post) => <ThoughtCard post={post} />)}
    </div>
    <a
      href={getLocalizedPath("/blog", locale)}
      class="reveal reveal-delay-2 self-end text-xs font-medium text-stone-400! transition-colors hover:text-[#6C969D]!"
    >
      {t("thoughts.viewAll")}
    </a>
  </div>
</section>
