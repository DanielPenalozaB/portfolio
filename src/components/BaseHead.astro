---
import "../styles/global.css";
import type { ImageMetadata } from "astro";
import { ClientRouter } from "astro:transitions";

import { getLocaleFromUrl, useTranslations, type Locale } from "../i18n";

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata;
}

const locale: Locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image } = Astro.props;
---

<ClientRouter />

<script is:inline data-astro-rerun>
  (function () {
    const stored = localStorage.getItem("theme");
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    if (stored === "dark" || (!stored && prefersDark)) {
      document.documentElement.classList.add("dark");
    }
  })();
</script>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={t("site.title")}
  href={new URL("rss.xml", Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<link
  rel="preload"
  href="/fonts/DMSans-VariableFont_opsz,wght.ttf"
  as="font"
  type="font/ttf"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/DMSerifDisplay-Italic.ttf"
  as="font"
  type="font/ttf"
  crossorigin
/>

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{/* eslint-disable astro/no-set-html-directive */}
<meta property="og:image" content={image ? new URL(image.src, Astro.url) : new URL("/images/profile.png", Astro.url)} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={image ? new URL(image.src, Astro.url) : new URL("/images/profile.png", Astro.url)} />
