---
import type { CollectionEntry } from "astro:content";
import type { Project } from "../data/projects";

interface Props {
  project?: Project;
  data?: CollectionEntry<"projects">["data"];
  class?: string;
  isFeatured?: boolean;
  darkStandalone?: boolean;
}

const {
  project: oldProject,
  data: newData,
  class: className,
  isFeatured,
  darkStandalone,
} = Astro.props;
const project = newData || oldProject;

if (!project) {
  throw new Error("ProjectCard requires either a 'project' or 'data' prop");
}

const slug = project.url?.split("/").pop() || "";
const titleColor = darkStandalone
  ? "text-stone-700! dark:text-stone-300!"
  : "text-stone-300!";
const tagBg = darkStandalone
  ? "bg-stone-200 text-stone-700 dark:bg-stone-700 dark:text-stone-100"
  : "bg-stone-700 text-stone-100";
---

<article
  class:list={[
    "group relative flex flex-col gap-4 overflow-hidden transition-transform duration-300",
    className,
  ]}
>
  <a
    href={project.url}
    class:list={[
      "overflow-hidden rounded-4xl p-4 backdrop-blur-sm transition-opacity duration-300 group-hover:opacity-80",
      darkStandalone
        ? "bg-stone-200/50 dark:bg-stone-400/15"
        : "bg-stone-400/15",
    ]}
  >
    <img
      src={project.image}
      alt={project.title}
      class="aspect-video h-full w-full rounded-2xl! object-cover sm:aspect-21/9"
      transition:name={`project-img-${slug}`}
    />
  </a>
  <div
    class="flex w-full flex-col items-start gap-4 sm:flex-row sm:items-center"
  >
    <h3
      class:list={[
        "min-w-0 shrink truncate text-3xl font-medium",
        titleColor,
      ]}
      title={project.title}
      transition:name={`project-title-${slug}`}
    >
      {project.title}
    </h3>

    <div class="flex shrink-0 items-center gap-4">
      <svg
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        class="hidden shrink-0 sm:block"
      >
        <g clip-path="url(#clip0_47_323)">
          <path
            d="M9.5 4.37869L12.5962 1.28244L14.7175 3.40381L11.6213 6.5H16V9.5H11.6213L14.7175 12.5962L12.5962 14.7175L9.5 11.6213V16H6.5V11.6213L3.40375 14.7175L1.2825 12.5962L4.37869 9.5H0V6.5H4.37869L1.28244 3.40375L3.40381 1.2825L6.5 4.37869V0H9.5V4.37869Z"
            fill="#78716C"></path>
        </g>
        <defs>
          <clipPath id="clip0_47_323">
            <rect width="16" height="16" fill="white"></rect>
          </clipPath>
        </defs>
      </svg>
      {
        project.tags.length > 0 && (
          <span class:list={["shrink-0 rounded-md px-2 py-1 text-sm whitespace-nowrap", tagBg]}>
            {project.tags[0]}
          </span>
        )
      }
    </div>

    <div
      class:list={[
        "flex shrink gap-2 overflow-hidden",
        !isFeatured && "hidden",
      ]}
    >
      {
        project.tags
          .slice(1, 3)
          .map((tag) => (
            <span class:list={["rounded-md px-2 py-1 text-sm whitespace-nowrap", tagBg]}>
              {tag}
            </span>
          ))
      }
    </div>
  </div>
</article>
