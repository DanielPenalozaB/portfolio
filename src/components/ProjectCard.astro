---
import type { CollectionEntry } from "astro:content";
import type { Project } from "../data/projects";

interface Props {
  project?: Project;
  data?: CollectionEntry<"projects">["data"];
  class?: string;
}

const { project: oldProject, data: newData, class: className } = Astro.props;
const project = newData || oldProject;

if (!project) {
  throw new Error("ProjectCard requires either a 'project' or 'data' prop");
}
---

<article
  class:list={[
    "group relative flex flex-col gap-4 overflow-hidden transition-transform duration-300",
    className,
  ]}
>
  <a
    href={project.url}
    target="_blank"
    class="overflow-hidden rounded-4xl bg-stone-400/15 p-4 backdrop-blur-sm transition-opacity duration-300 group-hover:opacity-80"
  >
    <img
      src={project.image}
      alt={project.title}
      class="aspect-video h-full w-full rounded-2xl! object-cover"
    />
  </a>
  <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center">
    <h3 class="truncate text-3xl font-medium whitespace-nowrap text-stone-300!">
      {project.title}
    </h3>
    <svg
      width="16"
      height="16"
      viewBox="0 0 16 16"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      class="hidden sm:block"
    >
      <g clip-path="url(#clip0_47_323)">
        <path
          d="M9.5 4.37869L12.5962 1.28244L14.7175 3.40381L11.6213 6.5H16V9.5H11.6213L14.7175 12.5962L12.5962 14.7175L9.5 11.6213V16H6.5V11.6213L3.40375 14.7175L1.2825 12.5962L4.37869 9.5H0V6.5H4.37869L1.28244 3.40375L3.40381 1.2825L6.5 4.37869V0H9.5V4.37869Z"
          fill="#78716C"></path>
      </g>
      <defs>
        <clipPath id="clip0_47_323">
          <rect width="16" height="16" fill="white"></rect>
        </clipPath>
      </defs>
    </svg>
    <div class="flex flex-wrap gap-2">
      {
        project.tags
          .slice(0, 3)
          .map((tag) => (
            <span class="rounded-md bg-stone-700 px-2 py-1 text-sm text-stone-100">
              {tag}
            </span>
          ))
      }
    </div>
  </div>
</article>
