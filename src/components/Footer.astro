---
import {
  getLocaleFromUrl,
  getLocalizedPath,
  useTranslations,
  type Locale,
} from "../i18n";

const locale: Locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer
  class="flex h-[625px] flex-col justify-end bg-linear-to-b from-stone-200/5 via-[#b0c4c8] to-[#8aabb2] dark:from-stone-900/5 dark:via-[#2a4a4f] dark:to-[#1f3b3f]"
>
  <div
    class="mx-auto flex w-full max-w-5xl flex-col items-center px-6 pt-20 pb-8 sm:px-10"
  >
    <!-- Main content -->
    <div
      class="flex w-fit flex-col gap-12 pb-12 md:w-full md:flex-row md:items-start md:justify-between"
    >
      <!-- Left: Made with + photo -->
      <div class="flex flex-col gap-5">
        <p class="text-sm font-medium text-white!">
          {t("footer.madeWith")} ❤️ {t("footer.andPassion")}
          <br />— Daniel Peñaloza
        </p>
        <img
          src="/images/profile.png"
          alt="Daniel Peñaloza"
          width="96"
          height="96"
          loading="lazy"
          class="h-24 w-24 rounded-2xl object-cover shadow-md"
        />
      </div>

      <!-- Right: Pages + Social columns -->
      <div class="flex gap-16 sm:gap-24">
        <div class="flex flex-col gap-3">
          <h3 class="text-sm font-bold text-white!">{t("footer.pages")}</h3>
          <nav
            aria-label={t("a11y.footerNav")}
            class="flex flex-col gap-2 text-sm text-white/70!"
          >
            <a
              href={getLocalizedPath("/", locale)}
              class="text-white! transition-colors"
            >
              {t("footer.home")}
            </a>
            <a
              href={getLocalizedPath("/#projects", locale)}
              class="text-white! transition-colors"
            >
              {t("nav.projects")}
            </a>
            <!-- TODO: About page — bio, timeline, interests, contact form -->
            <!--
            <a
              href={getLocalizedPath("/about", locale)}
              class="text-white! transition-colors"
            >
              {t("nav.about")}
            </a>
            -->
            <a
              href={getLocalizedPath("/#thoughts", locale)}
              class="text-white! transition-colors"
            >
              {t("nav.thoughts")}
            </a>
          </nav>
        </div>

        <div class="flex flex-col gap-3">
          <h3 class="text-sm font-bold text-white!">{t("footer.social")}</h3>
          <nav
            aria-label={t("a11y.socialNav")}
            class="flex flex-col gap-2 text-sm text-white/70!"
          >
            <a
              href="https://www.linkedin.com/in/juan-daniel-pe%C3%B1aloza-brito/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white! transition-colors"
            >
              LinkedIn
            </a>
            <a
              href="https://github.com/danielpenalozab"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white! transition-colors"
            >
              Github
            </a>
          </nav>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col items-center justify-between gap-2 border-t border-white/20 pt-6 text-xs text-white/50 sm:flex-row md:w-full"
    >
      <span>&copy; {t("footer.copyright")} {year}</span>
      <span>{t("footer.rights")}</span>
    </div>
  </div>
</footer>
