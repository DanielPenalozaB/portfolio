---
import {
  getLocaleFromUrl,
  getLocalizedPath,
  useTranslations,
  type Locale,
} from "../i18n";

const locale: Locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="bg-gradient-to-b from-stone-200 via-[#b0c4c8] to-[#8aabb2]">
  <div class="mx-auto max-w-6xl px-6 pt-20 pb-8 sm:px-10">
    <!-- Main content -->
    <div
      class="flex flex-col gap-12 pb-12 md:flex-row md:items-start md:justify-between"
    >
      <!-- Left: Made with + photo -->
      <div class="flex flex-col gap-5">
        <p class="text-sm font-medium text-white">
          {t("footer.madeWith")} ❤️ {t("footer.andPassion")}
          <br />— Daniel Peñaloza
        </p>
        <img
          src="/images/profile.png"
          alt="Daniel Peñaloza"
          class="h-24 w-24 rounded-2xl object-cover shadow-md"
        />
      </div>

      <!-- Right: Pages + Social columns -->
      <div class="flex gap-16 sm:gap-24">
        <div class="flex flex-col gap-3">
          <h3 class="text-sm font-bold text-white">{t("footer.pages")}</h3>
          <nav class="flex flex-col gap-2 text-sm text-white/70">
            <a
              href={getLocalizedPath("/", locale)}
              class="transition-colors hover:text-white"
            >
              {t("footer.home")}
            </a>
            <a
              href={getLocalizedPath("/#projects", locale)}
              class="transition-colors hover:text-white"
            >
              {t("nav.projects")}
            </a>
            <a
              href={getLocalizedPath("/about", locale)}
              class="transition-colors hover:text-white"
            >
              {t("nav.about")}
            </a>
            <a
              href={getLocalizedPath("/#thoughts", locale)}
              class="transition-colors hover:text-white"
            >
              {t("nav.thoughts")}
            </a>
          </nav>
        </div>

        <div class="flex flex-col gap-3">
          <h3 class="text-sm font-bold text-white">{t("footer.social")}</h3>
          <nav class="flex flex-col gap-2 text-sm text-white/70">
            <a
              href="https://linkedin.com/in/danielpenalozab"
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors hover:text-white"
            >
              LinkedIn
            </a>
            <a
              href="https://github.com/danielpenalozab"
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors hover:text-white"
            >
              Github
            </a>
          </nav>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col items-center justify-between gap-2 border-t border-white/20 pt-6 text-xs text-white/50 sm:flex-row"
    >
      <span>&copy; {t("footer.copyright")} {year}</span>
      <span>{t("footer.rights")}</span>
    </div>
  </div>
</footer>
