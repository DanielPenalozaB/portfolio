---
import type { ExperienceEntry as ExperienceType } from "../data/experience";

interface Props {
  entry: ExperienceType;
}

const { entry } = Astro.props;
---

<div
  class="relative flex w-full flex-col items-stretch justify-between gap-4 px-2 py-4 md:flex-row md:items-center md:p-6"
>
  <h3
    class="m-0! h-min text-2xl! font-medium text-stone-600! md:text-4xl! md:leading-14! dark:text-stone-200!"
  >
    {entry.role}
  </h3>
  <div class="flex flex-col items-end md:gap-2">
    <a
      href={entry.companyUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group flex items-center gap-2"
    >
      <img
        src={entry.logo}
        alt={entry.company}
        class="h-full max-h-4 w-full max-w-4 md:max-h-6 md:max-w-6"
        loading="eager"
      />
      <p
        class="m-0! text-lg leading-8 font-medium text-nowrap text-stone-600 group-hover:text-[#6C969D] group-hover:underline dark:text-stone-300 md:text-2xl"
      >
        {entry.company}
      </p>
    </a>
    <span class="m-0! text-lg leading-8 font-medium text-stone-400 dark:text-stone-500 md:text-xl">
      {entry.period}
    </span>
  </div>
</div>
