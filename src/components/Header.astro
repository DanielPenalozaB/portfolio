---
import { NAV_LINKS } from "../consts";
import {
  getLocaleFromUrl,
  getLocalizedPath,
  useTranslations,
  type Locale,
} from "../i18n";

const locale: Locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const altLocale: Locale = locale === "en" ? "es" : "en";
---

<header class="sticky top-0 z-50">
  <nav
    aria-label={t("a11y.mainNav")}
    class="flex w-full justify-center border-b border-stone-200/50 bg-stone-100/80 backdrop-blur-md dark:border-stone-700/50 dark:bg-stone-900/80"
  >
    <div class="flex w-full max-w-5xl items-center justify-between p-4 md:p-8">
      <!-- Logo -->
      <a
        href={getLocalizedPath("/", locale)}
        class="h-10 w-10 shrink-0 rounded-full outline outline-[#6C969D]"
      >
        <img
          src="/images/profile.png"
          alt="Daniel Peñaloza - Home"
          width="40"
          height="40"
          class="h-10 w-10 rounded-full!"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden items-center gap-2 md:flex">
        {
          NAV_LINKS.map((link) => (
            <a
              href={getLocalizedPath(link.href, locale)}
              title={t(link.labelKey)}
              class="px-3.5 py-2 text-base font-medium text-stone-700! transition-colors hover:text-[#6C969D] dark:text-stone-300!"
            >
              {t(link.labelKey)}
            </a>
          ))
        }
        <a
          href={getLocalizedPath(Astro.url.pathname, altLocale)}
          class="ml-2 cursor-pointer rounded-full border border-stone-300 bg-stone-200/50 px-3 py-1 text-sm font-bold text-stone-600! transition-all hover:bg-stone-200 dark:border-stone-600 dark:bg-stone-700/50 dark:text-stone-300! dark:hover:bg-stone-600"
          title={altLocale === "en" ? "English" : "Español"}
        >
          {altLocale.toUpperCase()}
        </a>
        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle dark mode"
          class="ml-2 flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-stone-300 bg-stone-200/50 transition-all hover:bg-stone-200 dark:border-stone-600 dark:bg-stone-700/50 dark:hover:bg-stone-600"
        >
          <svg
            id="icon-sun"
            class="hidden h-5 w-5 text-amber-400"
            fill="currentColor"
            viewBox="0 0 20 20"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
              clip-rule="evenodd"></path>
          </svg>
          <svg
            id="icon-moon"
            class="h-5 w-5 text-stone-600"
            fill="currentColor"
            viewBox="0 0 20 20"
            aria-hidden="true"
          >
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
            ></path>
          </svg>
        </button>
      </div>

      <!-- Mobile Hamburger Button -->
      <button
        id="menu-toggle"
        class="flex h-10 w-10 items-center justify-center rounded-lg text-stone-700! hover:bg-stone-200 dark:text-stone-300! dark:hover:bg-stone-700 md:hidden"
        aria-label={t("a11y.toggleMenu")}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          id="menu-icon"
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16m-7 6h7"></path>
        </svg>
        <svg
          id="close-icon"
          class="hidden h-6 w-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu Dropdown -->
  <div
    id="mobile-menu"
    role="menu"
    aria-hidden="true"
    class="pointer-events-none absolute top-full left-0 isolate flex w-full origin-top -translate-y-2 flex-col gap-2 border-b border-stone-200 bg-stone-100/70 p-6 opacity-0 shadow-xl backdrop-blur-md transition-all duration-300 ease-out dark:border-stone-700 dark:bg-stone-900/70 md:hidden"
  >
    {
      NAV_LINKS.map((link) => (
        <a
          href={getLocalizedPath(link.href, locale)}
          class="rounded-lg px-4 py-3 text-lg font-medium text-stone-700! hover:bg-stone-500/10 dark:text-stone-200!"
        >
          {t(link.labelKey)}
        </a>
      ))
    }
    <div
      class="mt-4 flex items-center justify-between border-t border-stone-200 pt-4 dark:border-stone-700"
    >
      <a
        href={getLocalizedPath(Astro.url.pathname, altLocale)}
        class="flex items-center gap-2 rounded-lg px-4 py-3 text-lg font-bold text-stone-700! hover:bg-stone-500/10 dark:text-stone-200!"
      >
        <span>{altLocale === "en" ? "English" : "Español"}</span>
        <span
          class="rounded-md border border-stone-300 px-2 py-0.5 text-xs text-stone-500! dark:border-stone-600 dark:text-stone-400!"
        >
          {altLocale.toUpperCase()}
        </span>
      </a>
      <button
        id="theme-toggle-mobile"
        type="button"
        aria-label="Toggle dark mode"
        class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-lg hover:bg-stone-500/10"
      >
        <svg
          class="icon-sun-mobile hidden h-5 w-5 text-amber-400"
          fill="currentColor"
          viewBox="0 0 20 20"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
            clip-rule="evenodd"></path>
        </svg>
        <svg
          class="icon-moon-mobile h-5 w-5 text-stone-600 dark:text-stone-300"
          fill="currentColor"
          viewBox="0 0 20 20"
          aria-hidden="true"
        >
          <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  function initHeader() {
    // MOBILE MENU
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuIcon = document.getElementById("menu-icon");
    const closeIcon = document.getElementById("close-icon");

    if (menuToggle && mobileMenu && menuIcon && closeIcon) {
      const toggleMenu = (show: boolean) => {
        menuToggle.setAttribute("aria-expanded", String(show));
        mobileMenu.setAttribute("aria-hidden", String(!show));

        if (show) {
          mobileMenu.classList.remove(
            "opacity-0",
            "pointer-events-none",
            "-translate-y-2",
          );
          mobileMenu.classList.add("opacity-100", "translate-y-0");
          menuIcon.classList.add("hidden");
          closeIcon.classList.remove("hidden");
        } else {
          mobileMenu.classList.add(
            "opacity-0",
            "pointer-events-none",
            "-translate-y-2",
          );
          mobileMenu.classList.remove("opacity-100", "translate-y-0");
          menuIcon.classList.remove("hidden");
          closeIcon.classList.add("hidden");
        }
      };

      menuToggle.addEventListener("click", () => {
        const isOpen = mobileMenu.classList.contains("opacity-100");
        toggleMenu(!isOpen);
      });

      mobileMenu.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          toggleMenu(false);
        });
      });

      document.addEventListener("click", (e) => {
        if (
          !menuToggle.contains(e.target as Node) &&
          !mobileMenu.contains(e.target as Node)
        ) {
          toggleMenu(false);
        }
      });
    }

    // THEME TOGGLE
    function updateThemeIcons(isDark: boolean) {
      const sun = document.getElementById("icon-sun");
      const moon = document.getElementById("icon-moon");
      const sunMobile = document.querySelector(".icon-sun-mobile");
      const moonMobile = document.querySelector(".icon-moon-mobile");

      if (sun && moon) {
        sun.classList.toggle("hidden", !isDark);
        moon.classList.toggle("hidden", isDark);
      }
      if (sunMobile && moonMobile) {
        sunMobile.classList.toggle("hidden", !isDark);
        moonMobile.classList.toggle("hidden", isDark);
      }
    }

    function toggleTheme() {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      updateThemeIcons(isDark);
    }

    updateThemeIcons(document.documentElement.classList.contains("dark"));

    document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
    document
      .getElementById("theme-toggle-mobile")
      ?.addEventListener("click", toggleTheme);
  }

  initHeader();
  document.addEventListener("astro:page-load", initHeader);
</script>
