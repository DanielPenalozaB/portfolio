---
import type { CollectionEntry } from "astro:content";
import { getLocaleFromUrl, useTranslations, type Locale } from "../i18n";
import Layout from "./Layout.astro";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, description, image, tags, repo } = project.data;
const locale: Locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const backUrl = locale === "es" ? "/es/projects" : "/projects";
const slug = project.id.split("/").pop() || "";
---

<Layout title={title} description={description}>
  <article class="flex min-h-screen flex-col items-center px-6 py-20 sm:px-10">
    <div class="flex w-full max-w-3xl flex-col gap-10">
      <nav class="reveal">
        <a
          href={backUrl}
          class="inline-flex items-center gap-2 text-sm text-stone-500 transition-colors hover:text-stone-800 dark:text-stone-400 dark:hover:text-stone-200"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M10 12L6 8L10 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          {t("projects.backToAll")}
        </a>
      </nav>

      <header class="reveal reveal-delay-1 flex flex-col gap-6">
        <div class="overflow-hidden rounded-3xl">
          <img
            src={image}
            alt={title}
            class="aspect-video w-full object-cover"
            transition:name={`project-img-${slug}`}
          />
        </div>

        <div class="flex flex-col gap-4">
          <h1
            class="dm-serif-display text-4xl font-bold text-stone-800 sm:text-5xl dark:text-stone-100"
            transition:name={`project-title-${slug}`}
          >
            {title}
          </h1>

          <p class="text-lg text-stone-600 dark:text-stone-400">
            {description}
          </p>

          <div class="flex flex-wrap items-center gap-3">
            {
              tags.map((tag) => (
                <span class="rounded-md bg-stone-200 px-2.5 py-1 text-sm text-stone-700 dark:bg-stone-700 dark:text-stone-200">
                  {tag}
                </span>
              ))
            }
          </div>

          {
            repo && (
              <a
                href={repo}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex w-fit items-center gap-2 rounded-lg bg-stone-800 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-stone-700 dark:bg-stone-200 dark:text-stone-800 dark:hover:bg-stone-300"
              >
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                </svg>
                {t("projects.viewRepo")}
              </a>
            )
          }
        </div>
      </header>

      <div
        class="prose-content prose prose-stone max-w-none dark:prose-invert"
      >
        <slot />
      </div>
    </div>
  </article>
</Layout>
